# =============================================================================
# Telegram Bot Configuration
# =============================================================================

# Telegram Bot Token (получите у @BotFather в Telegram)
TG_BOT_TOKEN=your_telegram_bot_token_here

# Admin IDs (через запятую)
ADMIN_IDS=123456789,987654321

# Telegram Polling
ENABLE_TG_POLLING=1
DROP_PENDING_UPDATES=1

# SSL Configuration (for proxy/corporate network issues)
# TG_DISABLE_SSL_VERIFY=1  # Disable SSL verification (INSECURE, dev only!)
# TG_SSL_CA_FILE=/path/to/ca_bundle.pem  # Custom CA certificate file

# =============================================================================
# Ozon Seller API Configuration (a-ulianov/OzonAPI style)
# =============================================================================

# Основные креденшалы (обязательно)
# Получите в личном кабинете продавца Ozon: Настройки -> API
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key

# Креденшалы для записи (опционально, если отличаются от read)
# OZON_WRITE_CLIENT_ID=your_ozon_write_client_id
# OZON_WRITE_API_KEY=your_ozon_write_api_key

# OAuth токен (альтернатива api_key, если используется OAuth авторизация)
# OZON_OAUTH_TOKEN=your_oauth_token

# -----------------------------------------------------------------------------
# Rate Limiting (рекомендуемые значения для Ozon API)
# -----------------------------------------------------------------------------
# Максимум запросов в секунду (документация: 50, рекомендуется: 25-27)
OZON_MAX_RPS=27

# Лимит одновременных соединений
OZON_CONNECTOR_LIMIT=100
OZON_CONNECTOR_LIMIT_PER_HOST=30

# -----------------------------------------------------------------------------
# Retry Configuration (экспоненциальный backoff)
# -----------------------------------------------------------------------------
# Максимальное количество попыток при ошибках
OZON_MAX_RETRIES=5

# Задержка между ретраями (секунды)
OZON_RETRY_MIN_WAIT=1.0
OZON_RETRY_MAX_WAIT=10.0

# Множитель для экспоненциального роста задержки
OZON_RETRY_MULTIPLIER=2.0

# -----------------------------------------------------------------------------
# Timeouts (секунды)
# -----------------------------------------------------------------------------
OZON_TOTAL_TIMEOUT=60.0
OZON_CONNECT_TIMEOUT=10.0
OZON_SOCK_READ_TIMEOUT=30.0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Логировать каждый API запрос (true/false)
OZON_ENABLE_REQUEST_LOGGING=true

# Уровень логирования для Ozon API
OZON_LOG_LEVEL=INFO

# Файл логов для Ozon API (опционально)
# OZON_LOG_FILE=logs/ozon_api.log
# OZON_LOG_MAX_BYTES=10485760
# OZON_LOG_BACKUP_FILES_COUNT=5

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
# Включить кеширование статичных данных
OZON_ENABLE_CACHE=true

# TTL кеша в секундах (для категорий, атрибутов и т.п.)
OZON_CACHE_TTL_SECONDS=3600

# Директория для кеша (опционально)
# OZON_CACHE_DIR=data/ozon_cache

# -----------------------------------------------------------------------------
# Metrics
# -----------------------------------------------------------------------------
# Включить сбор метрик производительности
OZON_ENABLE_METRICS=false

# Файл для записи метрик (опционально)
# OZON_METRICS_FILE=logs/ozon_metrics.json

# Режим отладки (подробное логирование)
OZON_DEBUG_MODE=false

# =============================================================================
# OpenAI Configuration (для AI-генерации ответов)
# =============================================================================

OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=500
# OPENAI_TEMPERATURE=0.7

# =============================================================================
# Storage & Database
# =============================================================================

STORAGE_DIR=data

# PostgreSQL (опционально)
USE_POSTGRES=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telegram_bot
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=your_password

# Redis (опционально)
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# =============================================================================
# Webhook (for production)
# =============================================================================

USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Features
# =============================================================================

ENABLE_PREFETCH=true
ENABLE_INLINE_QUERY=true

# =============================================================================
# CDEK API v2 Configuration
# =============================================================================

# CDEK API credentials (из личного кабинета CDEK: https://lk.cdek.ru/integration)
# Account/Идентификатор и Secure password/Пароль
CDEK_CLIENT_ID=xe86peHOyAlVUhxuMLM8Sv3UHx9a86JV
CDEK_CLIENT_SECRET=viqkdnIH7LSr4fLbgo4bisVdBBQhrW76

# Base URL (prod: https://api.cdek.ru, test: https://api.edu.cdek.ru)
CDEK_BASE_URL=https://api.cdek.ru

# Данные отправителя (фиксированные)
CDEK_SENDER_CITY=Ижевск
CDEK_SENDER_NAME=Ваше имя
CDEK_SENDER_PHONE=+79991234567

# Тариф по умолчанию
CDEK_DEFAULT_TARIFF_NAME=Магистральный экспресс склад-склад

# Тип заказа:
# 1 = интернет-магазин (рекомендуется)
# 2 = доставка
CDEK_ORDER_TYPE=1

# ПВЗ отправителя (опционально)
# CDEK_SENDER_PVZ=IZHV...
