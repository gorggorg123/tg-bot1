# Required secrets (set in Render Dashboard)
TG_BOT_TOKEN=
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_WRITE_CLIENT_ID=
OZON_WRITE_API_KEY=
OPENAI_API_KEY=
ADMIN_IDS=

# CDEK (required if you use CDEK features)
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_SENDER_NAME=
CDEK_SENDER_PHONE=

# Runtime defaults
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
TG_ENABLE_SSL_VERIFY=1
DROP_PENDING_UPDATES=1
